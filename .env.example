# ============================================================
# SMART HOTEL MENU — ENVIRONMENT VARIABLES
# Copy these into Vercel → Project → Settings → Environment Variables
# ============================================================

# ─── DATABASE ───────────────────────────────────────────────
# Get this from https://neon.tech (free) — create a project
# and paste the "Connection string" here.
# It looks like: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── NEXTAUTH ────────────────────────────────────────────────
# Generate a random secret. You can use any random string, e.g.:
# Run in terminal: openssl rand -base64 32
# OR just paste any long random text here.
NEXTAUTH_SECRET="PASTE_ANY_LONG_RANDOM_STRING_HERE_eg_superSecretKey12345"

# Your deployed Vercel URL — e.g. https://smart-hotel-menu-swadesh.vercel.app
NEXTAUTH_URL="https://YOUR_VERCEL_URL.vercel.app"
