generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Settings {
  id          String   @id @default(cuid())
  hotelName   String   @default("LUXE DINING")
  adminUpiId  String?  @default("")
  loginBgUrl  String?
  updatedAt   DateTime @updatedAt
}

model Table {
  id          String   @id @default(cuid())
  tableNumber Int      @unique
  qrCodeUrl   String?
  orders      Order[]
  waiterId    String?
  waiter      User?    @relation("WaiterTables", fields: [waiterId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  dishes      Dish[]
}

model Dish {
  id           String      @id @default(cuid())
  name         String
  description  String?
  price        Float
  categoryId   String
  category     Category    @relation(fields: [categoryId], references: [id])
  imageUrl     String?
  isAvailable  Boolean     @default(true)
  hasPortions  Boolean     @default(false)
  halfPrice    Float?
  quarterPrice Float?
  orderItems   OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  tableId         String
  table           Table       @relation(fields: [tableId], references: [id])
  customerName    String?     // Name as Unique Customer ID
  chefInstruction String?     // Optional instructions to the chef
  status          String      @default("PENDING") // PENDING, PREPARING, SERVED, COMPLETED, CANCELLED
  paymentStatus   String      @default("UNPAID")  // UNPAID, PAID
  totalAmount     Float
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  dishId      String
  dish        Dish     @relation(fields: [dishId], references: [id])
  quantity    Int
  price       Float
  portion     String   @default("Full")
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?  
  role           String    @default("CUSTOMER") // ADMIN, WAITER, CUSTOMER
  accounts       Account[]
  sessions       Session[]
  tables         Table[]   @relation("WaiterTables")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
